{
  "manifest_version": 3,
  "name": "readXlater",
  "version": "0.3.0",
  "description": "Auto-sync your Twitter/X likes and bookmarks — no API needed",
  "permissions": ["storage"],
  "host_permissions": ["https://x.com/*", "https://twitter.com/*", "http://localhost:3000/*", "https://*.vercel.app/*"],
  "content_scripts": [
    {
      "matches": ["https://x.com/*", "https://twitter.com/*"],
      "js": ["dist/scraper.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "src/popup/popup.html"
  }
}
