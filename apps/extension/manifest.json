{
  "manifest_version": 3,
  "name": "readXlater",
  "version": "0.2.0",
  "description": "Auto-sync your Twitter/X likes and bookmarks — no API needed",
  "permissions": ["storage", "scripting", "tabs"],
  "host_permissions": ["https://x.com/*", "https://twitter.com/*", "http://localhost:3000/*", "https://*.vercel.app/*"],
  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "src/popup/popup.html"
  }
}
