# =============================================================================
# readXlater — Environment Variables
# =============================================================================
# Copy this to .env.local and fill in your values:
#   cp .env.example .env.local
# =============================================================================

# --- Supabase ---
# Create a free project at https://supabase.com
# Find these in: Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- API Key ---
# Shared secret between the web app and the Chrome extension.
# Generate with: openssl rand -hex 32
# Paste this same key into the extension popup when connecting.
API_KEY=your-api-key-here

# --- Local User ID ---
# Single-user mode. Leave as "local" or set to any string.
LOCAL_USER_ID=local

# --- OpenAI ---
# For AI categorization and semantic search.
# Get a key at https://platform.openai.com/api-keys
# Cost: ~$0.01 per 100 tweets categorized (gpt-4o-mini)
OPENAI_API_KEY=sk-your-openai-api-key-here
