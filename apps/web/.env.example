# =============================================================================
# readXlater — Environment Variables
# =============================================================================
# Copy this to .env.local and fill in your values:
#   cp .env.example .env.local
# =============================================================================

# --- Supabase ---
# Create a project at https://supabase.com
# Find these in: Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- Auth ---
# Generate with: openssl rand -base64 32
AUTH_SECRET=your-random-secret-here

# Your app URL (http://localhost:3000 for dev, your domain for production)
AUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true

# --- Twitter OAuth 2.0 ---
# Create an app at https://developer.x.com
# Callback URL: {AUTH_URL}/api/auth/callback/twitter
# Required scopes: users.read, tweet.read, like.read, bookmark.read, offline.access
TWITTER_CLIENT_ID=your-twitter-client-id
TWITTER_CLIENT_SECRET=your-twitter-client-secret

# --- OpenAI ---
# For AI categorization and semantic search
# Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here
